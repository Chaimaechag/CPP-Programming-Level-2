/**
 * Concept: Allocating array size at runtime to optimize memory usage, 
 * using pointer arithmetic for element access.
 */

#include <iostream>

using namespace std;

int main() {
    int numberOfStudents;
    
    cout << "========================================" << endl;
    cout << "       STUDENT GRADES SYSTEM            " << endl;
    cout << "========================================" << endl;
    
    // 1. Get the exact size needed at runtime
    cout << "Enter total number of students: ";
    cin >> numberOfStudents;

    // Safety check: Ensure the number is valid
    if (numberOfStudents <= 0) {
        cout << "Error: Number of students must be greater than 0." << endl;
        return 1;
    }

    // 2. Dynamic memory allocation for the array
    float *gradesPtr = new float[numberOfStudents];

    // 3. Input Data (Using Pointer Arithmetic)
    cout << "\n--- Entering Grades ---" << endl;
    for (int i = 0; i < numberOfStudents; i++) {
        cout << "Grade for Student " << (i + 1) << ": ";
        // *(gradesPtr + i) is exactly the same as gradesPtr[i]
        cin >> *(gradesPtr + i);
    }

    // 4. Output Data
    cout << "\n--- Displaying Grades ---" << endl;
    for (int i = 0; i < numberOfStudents; i++) {
        cout << "Student " << (i + 1) << " : " << *(gradesPtr + i) << endl;
    }

    // 5. CRITICAL: Freeing the dynamically allocated array
    // We MUST use [] to tell the OS to delete the entire array block
    delete[] gradesPtr;
    
    // 6. Security best practice
    gradesPtr = nullptr;

    cout << "\nMemory successfully released. Exiting..." << endl;
    return 0;
}
