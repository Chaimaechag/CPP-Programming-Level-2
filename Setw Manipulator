/**
 * Project: Student Academic Record Formatter
 * Goal: Professional table formatting using <iomanip> manipulators.
 */

#include <iostream>
#include <iomanip> // Core library for setw, left, and right

using namespace std;

int main()
{
    // Table Header
    cout << "-------------------------------------------------------------" << endl;
    cout << " " << left << setw(8) << "Code" 
         << "| " << setw(31) << "Subject Name" 
         << "| " << setw(8) << "Mark" << " |" << endl;
    cout << "---------|--------------------------------|---------|" << endl;

    // Table Data Rows
    // Each setw ensures the '|' pipes line up perfectly
    cout << " " << left << setw(8) << "C101" 
         << "| " << setw(31) << "Introduction to Programming" 
         << "| " << setw(8) << "95" << " |" << endl;

    cout << " " << left << setw(8) << "C102" 
         << "| " << setw(31) << "Computer Hardware" 
         << "| " << setw(8) << "80" << " |" << endl;

    cout << " " << left << setw(8) << "N201" 
         << "| " << setw(31) << "Networking Fundamentals" 
         << "| " << setw(8) << "100" << " |" << endl;

    cout << "-------------------------------------------------------------" << endl;

    return 0;
}
