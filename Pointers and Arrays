/**
 * Concept: Array Decay & Pointer Arithmetic
 */

#include <iostream>
using namespace std;

int main() {
    int arr[4] = {10, 20, 30, 40};
    int *ptr = arr; // ptr points to arr[0]

    cout << "Index\tAddress\t\tValue" << endl;
    cout << "-----\t-------\t\t-----" << endl;

    for (int i = 0; i < 4; i++) {
        // Using pointer arithmetic to access elements
        cout << i << "\t" << (ptr + i) << "\t" << *(ptr + i) << endl;
    }

    // Pro-tip: arr[i] is actually converted to *(arr + i) by the compiler!
    return 0;
}
