/**
 * Program: Array Traversal using Range-based for loop
 * Description: Demonstrates a modern C++ approach to iterate over an array
 * without using traditional index-based loops.
 */

#include <iostream>

using namespace std;

int main()
{
    // Initialize an integer array with 6 elements
    int arr[] = { 1, 2, 3, 4, 5, 6 };

    // Range-based for loop: 'n' takes the value of each element in 'arr' automatically
    // This is safer and cleaner than using for (int i = 0; i < 6; i++)
    for (int n : arr)
    {
        cout << n << endl;
    }

    return 0;
}
